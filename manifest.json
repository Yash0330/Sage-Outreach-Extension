{
  "manifest_version": 3,
  "name": "Sage E-commerce Outreach",
  "version": "1.0",
  "description": "Local LinkedIn scraper and outreach bot.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://script.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
